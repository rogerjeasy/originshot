# ─── ListSnap backend env ───────────────────────────────────────────────
# Copy to `.env`. NEVER commit the real .env. See ../docs/SECURITY.md §5.

# App
APP_ENV=dev                 # dev | production
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# ── Local dev shortcuts (DO NOT enable in production) ──
# With these on, the API runs fully locally with NO Firebase / B2 / Redis:
#   - in-memory data store
#   - a fake authenticated dev user (auth bypass)
#   - generated assets are mocked from your upload and served from /media
AUTH_DEV_BYPASS=true

# ── Firebase (Auth + Firestore) — required in production ──
FIREBASE_PROJECT_ID=
# Path to the service-account JSON (Render: mount as a secret file)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Backblaze B2 (S3-compatible) — least-privilege key scoped to ONE bucket ──
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-000
# Leave blank to derive https://s3.<region>.backblazeb2.com
B2_ENDPOINT_URL=

# ── Redis / worker (production async jobs) ──
REDIS_URL=redis://localhost:6379

# ── Generation providers ──
GMI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LUMA_API_KEY=
ELEVENLABS_API_KEY=

# ── Limits & quotas (denial-of-wallet protection — SECURITY.md §10) ──
MAX_UPLOAD_MB=25
MAX_IMAGE_PIXELS=40000000
DAILY_GENERATION_QUOTA=50
PRESIGNED_URL_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=60