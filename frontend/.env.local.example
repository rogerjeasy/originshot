# Frontend env. Copy to `.env.local`. These NEXT_PUBLIC_* values are public by design
# (the Firebase web config is not a secret) but still lock them down via Firebase Auth
# authorized domains + API-key referrer restrictions. See ../docs/SECURITY.md §4/§5.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
