# ═══════════════════════════════════════════════════════════════════════════
#  OriginShot — single local env template (backend + frontend).
#  Copy to `.env` (at the repo root) and fill in real values:  cp .env.example .env
#  NEVER commit the real `.env` (it is gitignored). LOCAL DEV ONLY.
#  In PRODUCTION set backend vars in the Render dashboard and NEXT_PUBLIC_* vars in
#  the Vercel dashboard — do not ship this file. See docs/SECURITY.md §5.
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────── BACKEND (FastAPI) ────────────────────────────
# ── App ──
APP_ENV=dev                 # dev | production
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# Auth is always enforced. Keep this false; set Firebase below to sign in locally.
AUTH_DEV_BYPASS=false

# ── Firebase (Auth + Firestore) — required to sign in / persist ──
FIREBASE_PROJECT_ID=
# Path to the service-account JSON (Render: mount as a Secret File and point here).
GOOGLE_APPLICATION_CREDENTIALS=

# ── Backblaze B2 (S3-compatible) — least-privilege key scoped to ONE bucket ──
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-000
# Leave blank to derive https://s3.<region>.backblazeb2.com
B2_ENDPOINT_URL=

# ── Redis / worker (production async jobs) ──
# REDIS_URL=redis://localhost:6379

# ── Generation providers (set at least GMI to generate real assets) ──
GMI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LUMA_API_KEY=
ELEVENLABS_API_KEY=

# ── Limits & quotas (defaults shown) ──
MAX_UPLOAD_MB=25
MAX_IMAGE_PIXELS=40000000
DAILY_GENERATION_QUOTA=50
PRESIGNED_URL_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=60

# ── Credits (USD) ──
# The daily quota above caps request *volume*; credits cap *spend* — one video pack costs
# roughly 10x an image pack, so a request count alone can't bound cost. Every generation
# holds its estimated cost up front and settles against the provider's real per-step cost.
SIGNUP_CREDIT_GRANT=5.0
LOW_BALANCE_THRESHOLD=1.0

# ── Admin bootstrap ──
# Comma-separated emails treated as admins on sight; the role is written to their user
# document on first authenticated request. Required to mint the FIRST admin — granting the
# role through the API already requires being one. Only verified emails are accepted.
# Firestore roles remain the source of truth; this merely seeds them.
ADMIN_EMAILS=

# ── Mock generation: TESTS ONLY — do not enable here ──
# The mock fabricates assets by copying the user's upload and labelling them
# provider="mock-dev". Those rows are indistinguishable from real generations in analytics,
# the admin dashboard and the ledger. Off by default: when providers aren't configured the
# API returns an actionable 503 instead of serving fake media. Only tests/conftest.py sets
# this. Leaving it blank/false is correct for every real deployment.
MOCK_GENERATION_ENABLED=false

# ────────────────────────── FRONTEND (Next.js) ────────────────────────────
# Loaded by frontend/next.config.mjs. NEXT_PUBLIC_* are embedded in the browser
# bundle and are PUBLIC — never put a secret in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Judge/demo account (optional). When both are set, the sign-in page shows an
# "Explore a pre-loaded demo account" button. These are deliberately PUBLIC shared
# credentials — seed the account with scripts/seed-demo-account.py.
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=

# Post-generation QA (generate -> evaluate -> retry -> store). Deterministic Pillow checks
# always run when enabled; the VLM product-fidelity tier additionally uses GMI_API_KEY and
# degrades gracefully when the chat endpoint is unavailable. QA_RETRY_ENABLED regenerates a
# style at most ONCE when its output fails QA.
QA_ENABLED=true
QA_VLM_ENABLED=true
QA_RETRY_ENABLED=true
QA_VLM_TIMEOUT_SECONDS=60
