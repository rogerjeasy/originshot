# ═══════════════════════════════════════════════════════════════════════════
#  ListSnap — single local env template (backend + frontend).
#  Copy to `.env` (at the repo root) and fill in real values:  cp .env.example .env
#  NEVER commit the real `.env` (it is gitignored). LOCAL DEV ONLY.
#  In PRODUCTION set backend vars in the Render dashboard and NEXT_PUBLIC_* vars in
#  the Vercel dashboard — do not ship this file. See docs/SECURITY.md §5.
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────── BACKEND (FastAPI) ────────────────────────────
# ── App ──
APP_ENV=dev                 # dev | production
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000

# Auth is always enforced. Keep this false; set Firebase below to sign in locally.
AUTH_DEV_BYPASS=false

# ── Firebase (Auth + Firestore) — required to sign in / persist ──
FIREBASE_PROJECT_ID=
# Path to the service-account JSON (Render: mount as a Secret File and point here).
GOOGLE_APPLICATION_CREDENTIALS=

# ── Backblaze B2 (S3-compatible) — least-privilege key scoped to ONE bucket ──
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-000
# Leave blank to derive https://s3.<region>.backblazeb2.com
B2_ENDPOINT_URL=

# ── Redis / worker (production async jobs) ──
# REDIS_URL=redis://localhost:6379

# ── Generation providers (set at least GMI to generate real assets) ──
GMI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LUMA_API_KEY=
ELEVENLABS_API_KEY=

# ── Limits & quotas (defaults shown) ──
MAX_UPLOAD_MB=25
MAX_IMAGE_PIXELS=40000000
DAILY_GENERATION_QUOTA=50
PRESIGNED_URL_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=60

# ────────────────────────── FRONTEND (Next.js) ────────────────────────────
# Loaded by frontend/next.config.mjs. NEXT_PUBLIC_* are embedded in the browser
# bundle and are PUBLIC — never put a secret in a NEXT_PUBLIC_ var.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
